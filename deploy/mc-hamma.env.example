# mc-hamma local configuration
# Copy this file to mc-hamma.env and edit it.
# mc-hamma.env is NOT tracked by git.

# Serial port the MeshCore device is connected to
MC_SERIAL_PORT=/dev/ttyUSB0

# Serial baud rate (default: 115200)
MC_BAUD_RATE=115200

# Web server bind address (0.0.0.0 = all interfaces)
MC_HOST=0.0.0.0

# Web server port
MC_PORT=8080
